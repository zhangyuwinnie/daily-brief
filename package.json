{
  "name": "daily-brief-1",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "daily": "node --import dotenv/config scripts/daily-briefing.js --no-dedup",
    "daily:follow-builders": "node --import dotenv/config scripts/prepare-follow-builders.js | node --import dotenv/config scripts/remix-follow-builders.js",
    "daily:audio": "bash scripts/generate-audio.sh",
    "daily:all": "npm run daily && npm run daily:follow-builders && npm run daily:audio && npm run sync:generated",
    "sync:generated": "node --import tsx scripts/sync-generated-content.ts",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "publish:audio": "node --import tsx scripts/publish-audio.ts",
    "typecheck": "tsc -b --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "lucide-react": "^0.542.0",
    "openai": "^6.34.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.8.2"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1027.0",
    "@google/generative-ai": "^0.24.1",
    "@playwright/test": "^1.54.2",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "dotenv": "^17.2.3",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "postcss": "^8.4.49",
    "rss-parser": "^3.13.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^4.1.0"
  }
}
